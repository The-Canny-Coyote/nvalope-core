    "@vitest/coverage-v8": "^2.1.6",
    "eslint": "^9.15.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.12.0",
    "jsdom": "^25.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "4.1.12",
    "typescript": "^5.9.3",
