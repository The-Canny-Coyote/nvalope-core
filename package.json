    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "0.487.0",
    "motion": "12.23.24",
    "pdfjs-dist": "^4.10.38",
    "recharts": "^3.7.0",
    "sonner": "2.0.3",
    "tailwind-merge": "3.2.0",
