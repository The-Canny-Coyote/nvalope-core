{
  "name": "nvalope",
  "private": true,
  "version": "1.1.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "audit": "npm audit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "build": "vite build",
    "build:user-guide": "node scripts/build-user-guide-html.mjs",
    "deploy:pages": "npm run build && npx wrangler pages deploy dist --project-name=nvalope --branch=main && npx wrangler pages deploy dist --project-name=nvalope --branch=master",
    "dev": "vite",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:predeploy": "npm run test:run && npm run test:e2e",
    "generate:og": "node scripts/generate-og-image.mjs"
  },
  "dependencies": {
    "@mlc-ai/web-llm": "^0.2.80",
    "@radix-ui/react-alert-dialog": "1.1.6",
    "@radix-ui/react-checkbox": "1.1.4",
